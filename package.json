{
  "name": "yunshu-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "云枢中台 — 开箱即用的中台前端/设计解决方案",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish",
    "docs:dev": "turbo dev --filter=@yunshu/docs",
    "docs:build": "turbo build --filter=@yunshu/docs",
    "playground:dev": "turbo dev --filter=@yunshu/playground"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@yunshu/eslint-config": "workspace:*",
    "@yunshu/tsconfig": "workspace:*",
    "prettier": "^3.2.0",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
