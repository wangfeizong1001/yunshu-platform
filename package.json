{
  "name": "yunshu-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "云枢中台 — 开箱即用的中台前端/设计解决方案",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,vue,json,css,scss}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish",
    "docs:dev": "turbo dev --filter=@yunshu/docs",
    "docs:build": "turbo build --filter=@yunshu/docs",
    "playground:dev": "turbo dev --filter=@yunshu/playground",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.44.0",
    "@yunshu/eslint-config": "file:./tools/eslint-config",
    "@yunshu/tsconfig": "file:./tools/tsconfig",
    "prettier": "^3.2.0",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "vue": "3.4.29",
      "@vue/shared": "3.4.29",
      "@vue/compiler-dom": "3.4.29",
      "@vue/runtime-dom": "3.4.29",
      "@vue/compiler-sfc": "3.4.29",
      "@vue/server-renderer": "3.4.29",
      "@vue/reactivity": "3.4.29",
      "@vue/runtime-core": "3.4.29"
    }
  }
}
