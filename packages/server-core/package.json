{
  "name": "@yunshu/server-core",
  "version": "0.2.0",
  "private": false,
  "description": "云枢中台 — 后端核心基础设施，基于 PostgreSQL + Redis 构建，提供完整的数据访问、缓存、分布式锁能力",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@yunshu/shared": "workspace:*",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "@yunshu/tsconfig": "workspace:*",
    "@types/pg": "^8.10.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": false },
    "ioredis": { "optional": true }
  }
}
