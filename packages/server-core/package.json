{
  "name": "@yunshu/server-core",
  "version": "0.1.0",
  "private": false,
  "description": "云枢中台 — 后端核心基础设施，框架无关的 Service 层，基于 PostgreSQL 构建",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@yunshu/shared": "file:../shared",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0",
    "winston": "^3.13.0",
    "winston-loki": "^6.1.3"
  },
  "devDependencies": {
    "@yunshu/tsconfig": "file:../../tools/tsconfig",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
