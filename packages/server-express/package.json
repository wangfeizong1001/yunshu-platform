{
  "name": "@yunshu/server-express",
  "version": "0.1.0",
  "private": false,
  "description": "云枢中台 — Express 适配器，BaseController + 全类型错误处理 + 中间件集合",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@yunshu/server-core": "workspace:*",
    "@yunshu/shared": "workspace:*",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@yunshu/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  }
}
