    /**
     * 构建查询条件
     */
    private LambdaQueryWrapper<{{className}}> buildQueryWrapper({{className}}DTO dto) {
        LambdaQueryWrapper<{{className}}> wrapper = new LambdaQueryWrapper<>();
{{#each columns}}
{{#if queryType}}
        {{#ifCond queryType '==' 'eq'}}
        if ({{../javaField}} != null) {
            wrapper.eq({{../className}}::get{{capitalize javaField}}, dto.get{{capitalize javaField}}());
        }
        {{/ifCond}}
        {{#ifCond queryType '==' 'like'}}
        if (StringUtils.hasText(dto.get{{capitalize javaField}}())) {
            wrapper.like({{../className}}::get{{capitalize javaField}}, dto.get{{capitalize javaField}}());
        }
        {{/ifCond}}
        {{#ifCond queryType '==' 'gt'}}
        if (dto.get{{capitalize javaField}}() != null) {
            wrapper.gt({{../className}}::get{{capitalize javaField}}, dto.get{{capitalize javaField}}());
        }
        {{/ifCond}}
        {{#ifCond queryType '==' 'lt'}}
        if (dto.get{{capitalize javaField}}() != null) {
            wrapper.lt({{../className}}::get{{capitalize javaField}}, dto.get{{capitalize javaField}}());
        }
        {{/ifCond}}
        {{#ifCond queryType '==' 'in'}}
        if (dto.get{{capitalize javaField}}() != null && !dto.get{{capitalize javaField}}().isEmpty()) {
            wrapper.in({{../className}}::get{{capitalize javaField}}, dto.get{{capitalize javaField}}());
        }
        {{/ifCond}}
{{/if}}
{{/each}}
        return wrapper;
    }

