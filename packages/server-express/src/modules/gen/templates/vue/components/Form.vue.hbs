<template>
  <el-dialog
    v-model="visible"
    :title="formData.{{javaField}} ? '编辑{{functionName}}' : '新增{{functionName}}'"
    width="600px"
    @close="handleClose"
  >
    <el-form ref="formRef" :model="form" :rules="rules" label-width="100px">
{{#each columns}}
{{#unless isFill}}
      <el-form-item label="{{columnComment}}" prop="{{javaField}}">
{{#ifCond displayType '==' 'select'}}
        <el-select v-model="form.{{javaField}}" placeholder="请选择{{columnComment}}" style="width: 100%">
          <el-option label="正常" value="0" />
          <el-option label="停用" value="1" />
        </el-select>
{{else ifCond displayType '==' 'radio'}}
        <el-radio-group v-model="form.{{javaField}}">
          <el-radio label="0">正常</el-radio>
          <el-radio label="1">停用</el-radio>
        </el-radio-group>
{{else ifCond displayType '==' 'textarea'}}
        <el-input v-model="form.{{javaField}}" type="textarea" :rows="3" placeholder="请输入{{columnComment}}" />
{{else ifCond displayType '==' 'editor'}}
        <Editor v-model="form.{{javaField}}" />
{{else ifCond displayType '==' 'image'}}
        <UploadImage v-model="form.{{javaField}}" />
{{else ifCond displayType '==' 'file'}}
        <UploadFile v-model="form.{{javaField}}" />
{{else ifCond dataType '==' 'datetime'}}
        <el-date-picker
          v-model="form.{{javaField}}"
          type="datetime"
          placeholder="请选择{{columnComment}}"
          style="width: 100%"
          value-format="YYYY-MM-DD HH:mm:ss"
        />
{{else ifCond dataType '==' 'date'}}
        <el-date-picker
          v-model="form.{{javaField}}"
          type="date"
          placeholder="请选择{{columnComment}}"
          style="width: 100%"
          value-format="YYYY-MM-DD"
        />
{{else}}
        <el-input v-model="form.{{javaField}}" placeholder="请输入{{columnComment}}" />
{{/ifCond}}
      </el-form-item>
{{/unless}}
{{/each}}
    </el-form>

    <template #footer>
      <el-button @click="handleClose">取消</el-button>
      <el-button type="primary" @click="handleSubmit">确定</el-button>
    </template>
  </el-dialog>
</template>

<script setup lang="ts">
import { ref, reactive, watch } from 'vue'
import { ElMessage } from 'element-plus'
import type { FormInstance, FormRules } from 'element-plus'
{{#if generateTypeScript}}
import type { I{{className}} } from '@/types/{{toCamelCase className}}.types'
import * as {{toCamelCase className}}Api from '@/api/{{toCamelCase className}}.api'
{{else}}
import * as {{toCamelCase className}}Api from '@/api/{{toCamelCase className}}.api'
{{/if}}

const props = defineProps<{
  modelValue: boolean
  formData?: I{{className}} | null
}>()

const emit = defineEmits<{
  (e: 'update:modelValue', value: boolean): void
  (e: 'success'): void
}>()

const visible = ref(false)
const formRef = ref<FormInstance>()
const form = reactive<Partial<I{{className}}>>({})

const rules: FormRules = {
{{#each columns}}
{{#unless isFill}}
{{#ifCond isNullable '==' 'NO'}}
  {{javaField}}: [{ required: true, message: '请输入{{columnComment}}', trigger: 'blur' }],
{{/ifCond}}
{{/unless}}
{{/each}}
}

watch(() => props.modelValue, (val) => {
  visible.value = val
  if (val && props.formData) {
    Object.assign(form, props.formData)
  }
})

watch(visible, (val) => {
  emit('update:modelValue', val)
})

const handleClose = () => {
  formRef.value?.resetFields()
  visible.value = false
}

const handleSubmit = async () => {
  try {
    await formRef.value?.validate()
    if (form.{{javaField}}) {
      await {{toCamelCase className}}Api.update{{className}}(form.{{javaField}} as any, form)
      ElMessage.success('更新成功')
    } else {
      await {{toCamelCase className}}Api.create{{className}}(form)
      ElMessage.success('创建成功')
    }
    emit('success')
    handleClose()
  } catch {
    // 验证失败或请求失败
  }
}
</script>
