{
  "name": "@yunshu/ui",
  "version": "0.1.0",
  "private": false,
  "description": "云枢中台 — Vue 3 UI 组件库，基于设计令牌的三层组件架构",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/styles/main.css",
    "./scss": "./dist/styles/main.scss"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@yunshu/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@yunshu/tsconfig": "workspace:*",
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
