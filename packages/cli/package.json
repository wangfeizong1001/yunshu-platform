{
  "name": "@yunshu/cli",
  "version": "0.1.0",
  "private": false,
  "description": "云枢中台 — 脚手架 CLI 工具，项目创建、代码生成、主题定制",
  "type": "module",
  "bin": {
    "yunshu": "./dist/index.js",
    "create-yunshu": "./dist/create.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/create.ts --format esm --clean",
    "dev": "tsup src/index.ts src/create.ts --format esm --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/input": "^2.0.0",
    "@inquirer/select": "^3.0.0",
    "@inquirer/confirm": "^2.0.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@yunshu/tsconfig": "workspace:*",
    "tsup": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
