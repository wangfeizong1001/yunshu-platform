# 生产环境配置
NODE_ENV=production

# 应用名称
VITE_APP_TITLE=云枢中台

# API 基础路径（根据实际部署地址修改）
VITE_API_BASE_URL=https://api.yunshu.com

# Mock 数据配置（生产环境禁用）
VITE_ENABLE_MOCK=false

# 代理配置（生产环境不使用代理）
VITE_ENABLE_PROXY=false

# 调试模式
VITE_ENABLE_DEBUG=false

# 类型检查（生产环境可以关闭以加快构建）
VITE_ENABLE_TYPE_CHECK=true

# 代码压缩
VITE_ENABLE_COMPRESSION=true
