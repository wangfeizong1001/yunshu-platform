# ================================
# 云枢中台环境变量配置
# ================================
# 复制此文件为 .env.local 并修改相应值

# ================================
# 应用配置
# ================================

# 应用标题
VITE_APP_TITLE=云枢中台

# 应用版本
VITE_APP_VERSION=1.0.0

# 公共路径（用于部署到子路径）
VITE_PUBLIC_PATH=/

# ================================
# API 配置
# ================================

# API 基础地址
VITE_API_BASE_URL=https://api.yunshu.dev

# API 超时时间（毫秒）
VITE_API_TIMEOUT=30000

# ================================
# 功能开关
# ================================

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=false

# 是否启用调试模式
VITE_ENABLE_DEBUG=false

# 是否启用权限控制
VITE_ENABLE_PERMISSION=true

# ================================
# 认证配置
# ================================

# Token 存储键名
VITE_TOKEN_KEY=yunshu_token

# Token 刷新间隔（毫秒）
VITE_TOKEN_REFRESH_INTERVAL=3600000

# ================================
# 国际化配置
# ================================

# 默认语言
VITE_DEFAULT_LOCALE=zh-CN

# 可用语言列表
VITE_SUPPORTED_LOCALES=zh-CN,en

# ================================
# 主题配置
# ================================

# 默认主题 (light | dark | auto)
VITE_DEFAULT_THEME=light

# 主题色
VITE_PRIMARY_COLOR=#409eff

# ================================
# 监控配置
# ================================

# Sentry DSN（性能监控）
VITE_SENTRY_DSN=

# ================================
# 日志配置
# ================================

# 日志级别 (debug | info | warn | error)
VITE_LOG_LEVEL=info

# 是否在控制台打印日志
VITE_ENABLE_LOG=true

# ================================
# SEO 配置
# ================================

# 网站 URL
VITE_SITE_URL=https://www.yunshu.dev

# 网站描述
VITE_SITE_DESCRIPTION=云枢中台 - 开箱即用的中台前端解决方案

# 网站关键词
VITE_SITE_KEYWORDS=云枢,中台,前端,Vue3,TypeScript

# ================================
# 第三方服务配置
# ================================

# 图标库 CDN
VITE_ICON_CDN=https://cdn.jsdelivr.net/npm/@iconify/vue

# ================================
# 开发环境配置
# ================================

# 开发服务器端口
VITE_DEV_PORT=3000

# 是否自动打开浏览器
VITE_DEV_OPEN=true

# 是否启用 HTTPS
VITE_DEV_HTTPS=false

# ================================
# 构建配置
# ================================

# 构建目标
VITE_BUILD_TARGET=es2015

# 是否生成 source map
VITE_BUILD_SOURCEMAP=true

# 是否进行 gzip 压缩
VITE_BUILD_GZIP=true

# 构建时清除 dist 目录
VITE_BUILD_CLEAN=true
