# ========================================
# 云枢中台 — 环境变量示例文件
# ========================================
# 复制此文件为 .env 并根据实际环境修改配置。
# 注意：
#   - .env 文件不应提交到版本控制（已加入 .gitignore）
#   - 生产环境务必修改 JWT_SECRET、数据库密码等敏感信息
#   - Docker Compose 启动时会自动读取宿主机 .env 文件
# ========================================

# ------------------------------------------------------------------------
# 运行环境
# ------------------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------------------
# 服务监听
# ------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3000

# CORS 允许的源（多个以逗号分隔，或使用通配符 *）
CORS_ORIGIN=*

# API 路由前缀
API_PREFIX=/api

# ------------------------------------------------------------------------
# PostgreSQL 数据库
# ------------------------------------------------------------------------
# 本地开发使用 localhost；使用 Docker Compose 时主机名为 postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=yunshu
POSTGRES_PASSWORD=yunshu123
POSTGRES_DB=yunshu

# 连接池配置（可选）
POSTGRES_MAX_POOL_SIZE=10
POSTGRES_MIN_POOL_SIZE=2
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_CONNECTION_TIMEOUT=5000

# SSL（云数据库一般需要开启）
POSTGRES_SSL=false

# ------------------------------------------------------------------------
# Redis 缓存
# ------------------------------------------------------------------------
# 本地开发使用 localhost；使用 Docker Compose 时主机名为 redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=yunshu123
REDIS_DB=0
REDIS_KEY_PREFIX=yunshu:

# ------------------------------------------------------------------------
# JWT 认证
# ------------------------------------------------------------------------
# ⚠️  生产环境务必修改为强随机字符串！
# 可通过以下命令生成：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-please

# JWT 访问令牌过期时间（15m = 15分钟，1h = 1小时，7d = 7天）
JWT_EXPIRES_IN=15m

# JWT 刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt 哈希轮数（越大越安全，但越慢，推荐 10-12）
BCRYPT_ROUNDS=10

# ------------------------------------------------------------------------
# 应用信息
# ------------------------------------------------------------------------
APP_NAME=yunshu-server
LOG_LEVEL=info

# ------------------------------------------------------------------------
# 缓存策略
# ------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_L1_MAX_SIZE=1000
