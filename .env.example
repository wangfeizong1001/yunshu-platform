/**
 * 环境变量配置示例
 * 复制此文件为 .env.local 并修改对应值
 */

# 应用名称
VITE_APP_TITLE=云枢中台

# API 基础路径
VITE_API_BASE_URL=/api

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=true

# 是否启用代理
VITE_ENABLE_PROXY=true

# 代理目标地址
VITE_PROXY_TARGET=http://localhost:8080

# 是否启用 HTTPS
VITE_ENABLE_HTTPS=false

# 是否启用调试模式
VITE_ENABLE_DEBUG=true

# 路由模式 (history / hash)
VITE_ROUTE_MODE=history

# 是否启用类型检查
VITE_ENABLE_TYPE_CHECK=true

# 是否启用代码压缩
VITE_ENABLE_COMPRESSION=true

# 应用版本
VITE_APP_VERSION=0.1.0

# 构建时间
VITE_BUILD_TIME=
