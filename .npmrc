# =============================================================================
# 云枢中台 — pnpm 全局配置文件
# =============================================================================
# 所有 workspace 子包统一使用此配置，请勿在子目录下创建独立的 .npmrc
#
# ⚠️  本项目严格使用 pnpm 作为唯一包管理器
#     严禁使用 npm install / yarn add
#     禁止直接编辑 pnpm-lock.yaml
# =============================================================================

# ---------- 包源 ----------
# 使用国内镜像加速安装（淘宝 npmmirror）
registry=https://registry.npmmirror.com/

# ---------- Workspace ----------
# 自动将 workspace 内包相互链接，无需手动 npm link
link-workspace-packages=true

# ---------- 安装行为 ----------
# 跳过 lifecycle scripts（如 postinstall / prepare），避免依赖构建脚本执行
# 注意：如有构建步骤的包需在 CI 或 scripts 中显式执行
ignore-scripts=true

# ---------- 版本强制校验（engine-strict） ----------
# 强制检查 node 版本与 engines 字段，不满足则拒绝安装
engine-strict=true

# ---------- 依赖解析 ----------
# hoist-level=3：将公共依赖提升到 .pnpm/node_modules，减少重复安装
# public-hoist-pattern：提升特定包到根目录，方便 ESLint/TypeScript/编辑器插件访问
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=*@types/*
public-hoist-pattern[]=*vitest*
public-hoist-pattern[]=*playwright*

# 允许的裸模块（flat node_modules，不报错）
# 仅限真正需要被 hoist 的包，不要随意添加
shamefully-hoist=false

# ---------- 缓存 ----------
# pnpm store 路径（默认 ~/.pnpm-store，可选自定义）
# store-dir=~/.pnpm-store

# 副作用：删除不再被引用的缓存包，CI 构建后执行可减少磁盘占用
# auto-install-peers=true  # 自动安装 peers 依赖，pnpm 9 默认行为
